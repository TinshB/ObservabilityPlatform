# ═══════════════════════════════════════════════════════════════════
# Observability Platform — Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════

# ── Image Tag ─────────────────────────────────────────────────────
IMAGE_TAG=latest

# ── Database ──────────────────────────────────────────────────────
DB_NAME=mydatabase
DB_USERNAME=myuser
DB_PASSWORD=mypassword

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=bXktc3VwZXItc2VjcmV0LWtleS1mb3Itand0LXRva2VuLXNpZ25pbmctdGhhdC1pcy1sb25nLWVub3VnaC1mb3ItaG1hYy1zaGE1MTI=

# ── AI/ML ─────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ML_SIDECAR_TIMEOUT=30000

# ── MinIO (Object Storage) ───────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_REPORT_BUCKET=reports

# ── Reports ───────────────────────────────────────────────────────
REPORT_RETENTION_DAYS=30
REPORT_EMAIL_FROM=reports@observability-platform.local
